<!DOCTYPE html>
<html lang="en" data-bs-theme="<%= (typeof darkMode !== 'undefined' && darkMode) ? 'dark' : 'light' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dental Clinic Management System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container-fluid">
      <a class="navbar-brand" href="/dashboard">BrightSmile Dental</a>
      <div class="ms-auto">
        <% if (user) { %>
          <span class="navbar-text text-white me-3">Hello, <%= user.name %> (<%= user.role %>)</span>
          <a class="btn btn-outline-light btn-sm" href="/logout">Logout</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="container-fluid mt-4">
    <div class="row">
      <% if (user) { %>
        <div class="col-md-2">
          <div class="list-group">
            <a class="list-group-item" href="/dashboard">Dashboard</a>
            <% if (user.role === 'Admin' || user.role === 'Subadmin') { %>
              <a class="list-group-item" href="/patients">Patient Management</a>
              <a class="list-group-item" href="/appointments">Appointment Management</a>
              <a class="list-group-item" href="/inventory">Inventory Management</a>
              <a class="list-group-item" href="/reports">Reports</a>
            <% } %>
            <% if (user.role === 'Admin') { %>
              <a class="list-group-item" href="/users">User Management</a>
              <a class="list-group-item" href="/settings">Settings</a>
            <% } %>
          </div>
        </div>
      <% } %>
      <div class="col-md-10">
        <%- body %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
