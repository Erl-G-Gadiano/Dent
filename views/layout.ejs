<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dental Clinic Management System</title>
  <link rel="stylesheet" href="/css/style.css" />
  <meta name="color-scheme" content="light">
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <a class="brand" href="/dashboard">BrightSmile Dental</a>
      <div class="user-info">
        <% if (user) { %>
          <span class="greeting">Hello, <%= user.name %> (<%= user.role %>)</span>
          <a class="logout" href="/logout">Logout</a>
        <% } %>
      </div>
    </div>
  </header>

  <div class="main">
    <% if (user) { %>
      <aside class="sidebar">
        <nav>
          <ul>
            <li><a href="/dashboard">Dashboard</a></li>
            <% if (user.role === 'Admin' || user.role === 'Subadmin') { %>
              <li><a href="/patients">Patient Management</a></li>
              <li><a href="/appointments">Appointment Management</a></li>
              <li><a href="/inventory">Inventory Management</a></li>
              <li><a href="/reports">Reports</a></li>
            <% } %>
            <% if (user.role === 'Admin') { %>
              <li><a href="/users">User Management</a></li>
              <li><a href="/settings">Settings</a></li>
            <% } %>
          </ul>
        </nav>
      </aside>
    <% } %>

    <main class="content">
      <%- body %>
    </main>
  </div>

</body>
</html>
