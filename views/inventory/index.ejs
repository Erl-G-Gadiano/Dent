<div class="card shadow-sm">
  <div class="card-body">
    <h2 class="h4">Inventory Management</h2>
    <form action="/inventory" method="POST" class="row g-2 mb-3">
      <div class="col-md-2"><input class="form-control" name="item_name" placeholder="Item name" required></div>
      <div class="col-md-2"><input class="form-control" name="category" placeholder="Category"></div>
      <div class="col-md-2"><input class="form-control" name="quantity" type="number" placeholder="Quantity" required></div>
      <div class="col-md-2"><input class="form-control" name="unit_price" type="number" step="0.01" placeholder="Unit price" required></div>
      <div class="col-md-2"><input class="form-control" name="supplier" placeholder="Supplier"></div>
      <div class="col-md-2"><input class="form-control" name="date_added" type="date" required></div>
      <div class="col-md-2"><button class="btn btn-primary">Add Item</button></div>
    </form>

    <table class="table table-striped">
      <thead>
        <tr><th>Item</th><th>Category</th><th>Qty</th><th>Unit Price</th><th>Supplier</th></tr>
      </thead>
      <tbody>
        <% inventory.forEach(item => { %>
          <tr>
            <td><%= item.item_name %></td>
            <td><%= item.category %></td>
            <td><%= item.quantity %></td>
            <td>$<%= item.unit_price %></td>
            <td><%= item.supplier %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
