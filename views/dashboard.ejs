<section class="dashboard">
  <div class="dashboard-header">
    <h1>Dashboard</h1>
    <p class="muted">Overview of clinic activity.</p>
  </div>

  <div class="kpis">
    <div class="kpi">
      <div class="kpi-title">Total Patients</div>
      <div class="kpi-value"><%= stats.patients %></div>
    </div>
    <div class="kpi">
      <div class="kpi-title">Total Appointments</div>
      <div class="kpi-value"><%= stats.appointments %></div>
    </div>
    <div class="kpi">
      <div class="kpi-title">Revenue</div>
      <div class="kpi-value">$<%= stats.revenue %></div>
    </div>
    <div class="kpi">
      <div class="kpi-title">Low Stock Items</div>
      <div class="kpi-value"><%= stats.lowStock %></div>
    </div>
  </div>

  <div class="upcoming">
    <h2>Upcoming Appointments</h2>
    <ul>
      <% stats.upcoming.forEach(item => { %>
        <li class="upcoming-item">
          <strong><%= item.title %></strong>
          <span class="date"><%= new Date(item.appointment_date).toLocaleString() %></span>
          <span class="status"><%= item.status %></span>
        </li>
      <% }) %>
    </ul>
  </div>
</section>
