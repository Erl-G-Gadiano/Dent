<div class="card shadow-sm">
  <div class="card-body">
    <h2 class="h4">Error</h2>
    <p><%= message %></p>
    <% if (user) { %>
      <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
    <% } else { %>
      <a href="/login" class="btn btn-primary">Go to Login</a>
    <% } %>
  </div>
</div>
